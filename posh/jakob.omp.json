{
  "$schema": "https://raw.githubusercontent.com/JanDeDobbeleer/oh-my-posh/main/themes/schema.json",
  "version": 4,
  "final_space": true,
  "patch_pwsh_bleed": true,
  "blocks": [
    {
      "type": "prompt",
      "alignment": "left",
      "newline": true,
      "segments": [
        {
          "type": "session",
          "style": "diamond",
          "leading_diamond": "",
          "trailing_diamond": "",
          "foreground": "#081018",
          "background": "#38bdf8",
          "template": " {{ .UserName }} "
        },
        {
          "type": "path",
          "style": "powerline",
          "powerline_symbol": "",
          "foreground": "#e6f1f5",
          "background": "#14323f",
          "template": "  {{ .Path }} ",
          "properties": {
            "style": "agnoster_short",
            "max_depth": 1,
            "folder_separator_icon": " › ",
            "home_icon": "~",
            "folder_icon": ""
          }
        },
        {
          "type": "git",
          "style": "powerline",
          "powerline_symbol": "",
          "foreground": "#07130f",
          "background": "#34d399",
          "background_templates": [
            "{{ if or (.Working.Changed) (.Staging.Changed) }}#2dd4bf{{ end }}",
            "{{ if and (gt .Ahead 0) (gt .Behind 0) }}#22c55e{{ end }}",
            "{{ if gt .Ahead 0 }}#6ee7b7{{ end }}",
            "{{ if gt .Behind 0 }}#14b8a6{{ end }}"
          ],
          "template": " {{ .HEAD }}{{ if .BranchStatus }} {{ .BranchStatus }}{{ end }} ",
          "properties": {
            "branch_template": "{{ trunc 25 .Branch }}",
            "fetch_status": true
          }
        }
      ]
    },
    {
      "type": "prompt",
      "alignment": "left",
      "newline": false,
      "segments": [
        {
          "type": "status",
          "style": "plain",
          "foreground": "#7dd3fc",
          "foreground_templates": [
            "{{ if gt .Code 0 }}#f87171{{ end }}"
          ],
          "template": "❯ ",
          "properties": {
            "always_enabled": true
          }
        }
      ]
    }
  ]
}