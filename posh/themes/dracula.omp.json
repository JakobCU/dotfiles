{
  "$schema": "https://raw.githubusercontent.com/JanDeDobbeleer/oh-my-posh/main/themes/schema.json",
  "version": 4,
  "final_space": true,
  "patch_pwsh_bleed": true,
  "blocks": [
    {
      "type": "prompt",
      "alignment": "left",
      "newline": true,
      "segments": [
        {
          "type": "session",
          "style": "diamond",
          "leading_diamond": "",
          "trailing_diamond": "",
          "foreground": "#282a36",
          "background": "#bd93f9",
          "template": " {{ .UserName }} "
        },
        {
          "type": "path",
          "style": "powerline",
          "powerline_symbol": "",
          "foreground": "#f8f8f2",
          "background": "#282a36",
          "template": "  {{ .Path }} ",
          "properties": {
            "style": "agnoster_short",
            "max_depth": 1,
            "folder_separator_icon": " › ",
            "home_icon": "~",
            "folder_icon": ""
          }
        },
        {
          "type": "git",
          "style": "powerline",
          "powerline_symbol": "",
          "foreground": "#282a36",
          "background": "#50fa7b",
          "background_templates": [
            "{{ if or (.Working.Changed) (.Staging.Changed) }}#f1fa8c{{ end }}",
            "{{ if and (gt .Ahead 0) (gt .Behind 0) }}#ff79c6{{ end }}",
            "{{ if gt .Ahead 0 }}#8be9fd{{ end }}",
            "{{ if gt .Behind 0 }}#ffb86c{{ end }}"
          ],
          "template": " {{ .HEAD }}{{ if .BranchStatus }} {{ .BranchStatus }}{{ end }} ",
          "properties": {
            "branch_template": "{{ trunc 25 .Branch }}",
            "fetch_status": true
          }
        }
      ]
    },
    {
      "type": "prompt",
      "alignment": "left",
      "newline": false,
      "segments": [
        {
          "type": "status",
          "style": "plain",
          "foreground": "#bd93f9",
          "foreground_templates": [
            "{{ if gt .Code 0 }}#ff5555{{ end }}"
          ],
          "template": "❯ ",
          "properties": {
            "always_enabled": true
          }
        }
      ]
    }
  ]
}