{
  "$schema": "https://raw.githubusercontent.com/JanDeDobbeleer/oh-my-posh/main/themes/schema.json",
  "version": 4,
  "final_space": true,
  "patch_pwsh_bleed": true,
  "blocks": [
    {
      "type": "prompt",
      "alignment": "left",
      "newline": true,
      "segments": [
        {
          "type": "session",
          "style": "diamond",
          "leading_diamond": "",
          "trailing_diamond": "",
          "foreground": "#282828",
          "background": "#d79921",
          "template": " {{ .UserName }} "
        },
        {
          "type": "path",
          "style": "powerline",
          "powerline_symbol": "",
          "foreground": "#ebdbb2",
          "background": "#3c3836",
          "template": "  {{ .Path }} ",
          "properties": {
            "style": "agnoster_short",
            "max_depth": 1,
            "folder_separator_icon": " › ",
            "home_icon": "~",
            "folder_icon": ""
          }
        },
        {
          "type": "git",
          "style": "powerline",
          "powerline_symbol": "",
          "foreground": "#282828",
          "background": "#98971a",
          "background_templates": [
            "{{ if or (.Working.Changed) (.Staging.Changed) }}#d65d0e{{ end }}",
            "{{ if and (gt .Ahead 0) (gt .Behind 0) }}#689d6a{{ end }}",
            "{{ if gt .Ahead 0 }}#b8bb26{{ end }}",
            "{{ if gt .Behind 0 }}#fabd2f{{ end }}"
          ],
          "template": " {{ .HEAD }}{{ if .BranchStatus }} {{ .BranchStatus }}{{ end }} ",
          "properties": {
            "branch_template": "{{ trunc 25 .Branch }}",
            "fetch_status": true
          }
        }
      ]
    },
    {
      "type": "prompt",
      "alignment": "left",
      "newline": false,
      "segments": [
        {
          "type": "status",
          "style": "plain",
          "foreground": "#fabd2f",
          "foreground_templates": [
            "{{ if gt .Code 0 }}#fb4934{{ end }}"
          ],
          "template": "❯ ",
          "properties": {
            "always_enabled": true
          }
        }
      ]
    }
  ]
}