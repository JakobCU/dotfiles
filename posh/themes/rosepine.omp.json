{
  "$schema": "https://raw.githubusercontent.com/JanDeDobbeleer/oh-my-posh/main/themes/schema.json",
  "version": 4,
  "final_space": true,
  "patch_pwsh_bleed": true,
  "blocks": [
    {
      "type": "prompt",
      "alignment": "left",
      "newline": true,
      "segments": [
        {
          "type": "session",
          "style": "diamond",
          "leading_diamond": "",
          "trailing_diamond": "",
          "foreground": "#191724",
          "background": "#ebbcba",
          "template": " {{ .UserName }} "
        },
        {
          "type": "path",
          "style": "powerline",
          "powerline_symbol": "",
          "foreground": "#e0def4",
          "background": "#1f1d2e",
          "template": "  {{ .Path }} ",
          "properties": {
            "style": "agnoster_short",
            "max_depth": 1,
            "folder_separator_icon": " › ",
            "home_icon": "~",
            "folder_icon": ""
          }
        },
        {
          "type": "git",
          "style": "powerline",
          "powerline_symbol": "",
          "foreground": "#191724",
          "background": "#9ccfd8",
          "background_templates": [
            "{{ if or (.Working.Changed) (.Staging.Changed) }}#f6c177{{ end }}",
            "{{ if and (gt .Ahead 0) (gt .Behind 0) }}#c4a7e7{{ end }}",
            "{{ if gt .Ahead 0 }}#ebbcba{{ end }}",
            "{{ if gt .Behind 0 }}#eb6f92{{ end }}"
          ],
          "template": " {{ .HEAD }}{{ if .BranchStatus }} {{ .BranchStatus }}{{ end }} ",
          "properties": {
            "branch_template": "{{ trunc 25 .Branch }}",
            "fetch_status": true
          }
        }
      ]
    },
    {
      "type": "prompt",
      "alignment": "left",
      "newline": false,
      "segments": [
        {
          "type": "status",
          "style": "plain",
          "foreground": "#c4a7e7",
          "foreground_templates": [
            "{{ if gt .Code 0 }}#eb6f92{{ end }}"
          ],
          "template": "❯ ",
          "properties": {
            "always_enabled": true
          }
        }
      ]
    }
  ]
}