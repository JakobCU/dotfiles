{
  "$schema": "https://raw.githubusercontent.com/JanDeDobbeleer/oh-my-posh/main/themes/schema.json",
  "version": 4,
  "final_space": true,
  "patch_pwsh_bleed": true,
  "blocks": [
    {
      "type": "prompt",
      "alignment": "left",
      "newline": true,
      "segments": [
        {
          "type": "session",
          "style": "diamond",
          "leading_diamond": "",
          "trailing_diamond": "",
          "foreground": "#2e3440",
          "background": "#88c0d0",
          "template": " {{ .UserName }} "
        },
        {
          "type": "path",
          "style": "powerline",
          "powerline_symbol": "",
          "foreground": "#eceff4",
          "background": "#3b4252",
          "template": "  {{ .Path }} ",
          "properties": {
            "style": "agnoster_short",
            "max_depth": 1,
            "folder_separator_icon": " › ",
            "home_icon": "~",
            "folder_icon": ""
          }
        },
        {
          "type": "git",
          "style": "powerline",
          "powerline_symbol": "",
          "foreground": "#2e3440",
          "background": "#a3be8c",
          "background_templates": [
            "{{ if or (.Working.Changed) (.Staging.Changed) }}#ebcb8b{{ end }}",
            "{{ if and (gt .Ahead 0) (gt .Behind 0) }}#b48ead{{ end }}",
            "{{ if gt .Ahead 0 }}#8fbcbb{{ end }}",
            "{{ if gt .Behind 0 }}#d08770{{ end }}"
          ],
          "template": " {{ .HEAD }}{{ if .BranchStatus }} {{ .BranchStatus }}{{ end }} ",
          "properties": {
            "branch_template": "{{ trunc 25 .Branch }}",
            "fetch_status": true
          }
        }
      ]
    },
    {
      "type": "prompt",
      "alignment": "left",
      "newline": false,
      "segments": [
        {
          "type": "status",
          "style": "plain",
          "foreground": "#81a1c1",
          "foreground_templates": [
            "{{ if gt .Code 0 }}#bf616a{{ end }}"
          ],
          "template": "❯ ",
          "properties": {
            "always_enabled": true
          }
        }
      ]
    }
  ]
}